38621>>>    Procedure SetActionButtons
38624>>>        tWebNavigateData NavigateData
38624>>>        tWebNavigateData NavigateData
38624>>>        Boolean bHasRecord
38624>>>        Handle hoDD
38624>>>
38624>>>        Get Server to hoDD
38625>>>        Get GetNavigateData to NavigateData
38626>>>        Get HasRecord of hoDD to bHasRecord
38627>>>
38627>>>        // let's hide all buttons and then Show the ones we want
38627>>>        WebSet pbRender of oEditBtn to False
38628>>>        WebSet pbRender of oSaveBtn to False
38629>>>        WebSet pbRender of oCancelChangesBtn to False
38630>>>        WebSet pbRender of oDeleteBtn to False
38631>>>
38631>>>        If (NavigateData.bReadOnly) Begin
38633>>>            WebSet pbRender of oEditBtn to True
38634>>>        End
38634>>>>
38634>>>        Else Begin
38635>>>            WebSet pbRender of oSaveBtn to True
38636>>>            WebSet pbRender of oCancelChangesBtn to True
38637>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38638>>>        End
38638>>>>
38638>>>    End_Procedure
38639>>>
38639>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38642>>>        // Close after save
38642>>>        Send NavigateClose Self
38643>>>    End_Procedure
38644>>>
38644>>>    // this will close the view after a delete
38644>>>    Procedure OnViewDeleted Handle hoDDO
38647>>>        Send NavigateClose Self
38648>>>    End_Procedure
38649>>>
38649>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38652>>>        Case Begin
38652>>>            Case (NavigateData.eNavigateType = nfFromMain)
38654>>>                // If from main, this is a propbably a main file Select to Zoom.
38654>>>                Case Break
38655>>>
38655>>>            Case (NavigateData.eNavigateType = nfFromParent)
38658>>>                // If from parent, this is a constrained drill down.
38658>>>                Case Break
38659>>>
38659>>>            Case (NavigateData.eNavigateType = nfFromChild)
38662>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38662>>>                Case Break
38663>>>
38663>>>            Case Else // must be nfUndefined
38663>>>
38663>>>        Case End
38663>>>
38663>>>        Send SetActionButtons
38664>>>
38664>>>    End_Procedure
38665>>>
38665>>>End_Object 
