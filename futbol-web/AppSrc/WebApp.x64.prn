38873>>>    Procedure SetActionButtons
38876>>>        tWebNavigateData NavigateData
38876>>>        tWebNavigateData NavigateData
38876>>>        Boolean bHasRecord
38876>>>        Handle hoDD
38876>>>
38876>>>        Get Server to hoDD
38877>>>        Get GetNavigateData to NavigateData
38878>>>        Get HasRecord of hoDD to bHasRecord
38879>>>
38879>>>        // let's hide all buttons and then Show the ones we want
38879>>>        WebSet pbRender of oEditBtn to False
38880>>>        WebSet pbRender of oSaveBtn to False
38881>>>        WebSet pbRender of oCancelChangesBtn to False
38882>>>        WebSet pbRender of oDeleteBtn to False
38883>>>
38883>>>        If (NavigateData.bReadOnly) Begin
38885>>>            WebSet pbRender of oEditBtn to True
38886>>>        End
38886>>>>
38886>>>        Else Begin
38887>>>            WebSet pbRender of oSaveBtn to True
38888>>>            WebSet pbRender of oCancelChangesBtn to True
38889>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38890>>>        End
38890>>>>
38890>>>    End_Procedure
38891>>>
38891>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38894>>>        // Close after save
38894>>>        Send NavigateClose Self
38895>>>    End_Procedure
38896>>>
38896>>>    // this will close the view after a delete
38896>>>    Procedure OnViewDeleted Handle hoDDO
38899>>>        Send NavigateClose Self
38900>>>    End_Procedure
