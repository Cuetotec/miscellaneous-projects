38904>>>        Case Begin
38904>>>            Case (NavigateData.eNavigateType = nfFromMain)
38906>>>                // If from main, this is a propbably a main file Select to Zoom.
38906>>>                Case Break
38907>>>
38907>>>            Case (NavigateData.eNavigateType = nfFromParent)
38910>>>                // If from parent, this is a constrained drill down.
38910>>>                Case Break
38911>>>
38911>>>            Case (NavigateData.eNavigateType = nfFromChild)
38914>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38914>>>                Case Break
38915>>>
38915>>>            Case Else // must be nfUndefined
38915>>>
38915>>>        Case End
38915>>>
38915>>>        Send SetActionButtons
38916>>>
38916>>>    End_Procedure
38917>>>
38917>>>End_Object 
